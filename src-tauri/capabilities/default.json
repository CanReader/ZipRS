{
  "$schema": "https://raw.githubusercontent.com/nickelpack/nck/main/packages/tauri-plugin/permissions/schemas/v2/schema.json",
  "identifier": "default",
  "description": "Default capabilities for ZipRS",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "dialog:default",
    "dialog:allow-open",
    "dialog:allow-save",
    "dialog:allow-ask",
    "fs:default",
    "fs:allow-read",
    "fs:allow-write",
    "shell:default",
    "opener:default"
  ]
}
