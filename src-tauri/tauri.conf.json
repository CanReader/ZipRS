{
  "$schema": "https://raw.githubusercontent.com/tauri-apps/tauri/dev/crates/tauri-config-schema/schema.json",
  "productName": "ZipRS",
  "version": "0.1.0",
  "identifier": "com.ziprs.archive-manager",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev:frontend",
    "beforeBuildCommand": "npm run build:frontend"
  },
  "app": {
    "windows": [
      {
        "title": "ZipRS — Archive Manager",
        "width": 1100,
        "height": 700,
        "minWidth": 800,
        "minHeight": 500,
        "decorations": true,
        "resizable": true,
        "dragDropEnabled": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis", "deb", "rpm", "appimage", "dmg"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": [
      "resources/*"
    ],
    "fileAssociations": [
      {
        "ext": ["zip", "jar", "war"],
        "mimeType": "application/zip",
        "description": "ZIP Archive",
        "role": "Editor"
      },
      {
        "ext": ["rar"],
        "mimeType": "application/vnd.rar",
        "description": "RAR Archive",
        "role": "Viewer"
      },
      {
        "ext": ["tar"],
        "mimeType": "application/x-tar",
        "description": "TAR Archive",
        "role": "Editor"
      },
      {
        "ext": ["gz", "tgz"],
        "mimeType": "application/gzip",
        "description": "GZip Archive",
        "role": "Editor"
      },
      {
        "ext": ["bz2", "tbz2"],
        "mimeType": "application/x-bzip2",
        "description": "BZip2 Archive",
        "role": "Editor"
      },
      {
        "ext": ["zst", "tzst"],
        "mimeType": "application/zstd",
        "description": "Zstandard Archive",
        "role": "Editor"
      }
    ],
    "copyright": "Copyright (c) 2024-2026 ZipRS Contributors",
    "category": "Utility",
    "shortDescription": "A fast, modern archive manager built with Rust",
    "longDescription": "ZipRS is a professional archive manager built with Rust and Tauri. It supports ZIP, TAR, GZ, BZ2, ZST, and RAR formats with both a modern GUI and a powerful CLI interface.",
    "publisher": "ZipRS",
    "license": "MIT",
    "licenseFile": "resources/LICENSE",
    "windows": {
      "nsis": {
        "displayLanguageSelector": true,
        "installMode": "both",
        "languages": ["English"],
        "installerHooks": "nsis/hooks.nsh"
      },
      "webviewInstallMode": {
        "type": "embedBootstrapper"
      }
    },
    "macOS": {
      "minimumSystemVersion": "10.15"
    },
    "linux": {
      "deb": {
        "depends": ["libwebkit2gtk-4.1-0", "libgtk-3-0"],
        "section": "utils",
        "priority": "optional"
      },
      "rpm": {
        "release": "1"
      },
      "appimage": {
        "bundleMediaFramework": false
      }
    }
  }
}
